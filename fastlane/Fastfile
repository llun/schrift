default_platform(:ios)

APP_IDENTIFIER = "dev.llun.Schrift"
XCODE_PROJECT  = "Schrift.xcodeproj"
SCHEME         = "Schrift"
PROFILE_NAME   = "match AppStore dev.llun.Schrift"

platform :ios do
  desc "Build a Release archive and upload it to TestFlight"
  lane :beta do
    # On CI, create a throwaway keychain so `match` can import the signing
    # certificate without touching (or being blocked by) the login keychain.
    setup_ci if ENV["CI"]

    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_KEY_CONTENT"],
      is_key_content_base64: true
    )

    # The .xcodeproj is not committed; it is generated from project.yml.
    # (fastlane runs from the fastlane/ dir, so hop up to the repo root.)
    sh("cd .. && xcodegen generate")

    # Fetch (readonly on CI) the distribution cert + provisioning profile
    # from the private match repo.
    match(
      type: "appstore",
      app_identifier: APP_IDENTIFIER,
      api_key: api_key,
      readonly: is_ci
    )

    # Point the (freshly regenerated) project at the match profile with manual
    # signing. Safe to mutate — xcodegen recreates the project every run.
    update_code_signing_settings(
      path: XCODE_PROJECT,
      use_automatic_signing: false,
      team_id: ENV["DEVELOPER_TEAM_ID"],
      bundle_identifier: APP_IDENTIFIER,
      code_sign_identity: "Apple Distribution",
      profile_name: PROFILE_NAME
    )

    # Monotonic build number. CI passes github.run_number via BUILD_NUMBER;
    # locally we bump past whatever is already on TestFlight.
    build_number =
      ENV["BUILD_NUMBER"] ||
      latest_testflight_build_number(
        api_key: api_key,
        app_identifier: APP_IDENTIFIER,
        initial_build_number: 0
      ).next.to_s

    # Marketing version. CI passes the Conventional-Commits value it computed
    # (scripts/next-version.sh) via MARKETING_VERSION; locally we leave it unset
    # so the build keeps project.yml's default.
    marketing_version = ENV["MARKETING_VERSION"]
    xcargs = "CURRENT_PROJECT_VERSION=#{build_number}"
    xcargs += " MARKETING_VERSION=#{marketing_version}" unless marketing_version.to_s.empty?

    build_app(
      project: XCODE_PROJECT,
      scheme: SCHEME,
      configuration: "Release",
      export_method: "app-store",
      xcargs: xcargs,
      export_options: {
        method: "app-store",
        signingStyle: "manual",
        provisioningProfiles: { APP_IDENTIFIER => PROFILE_NAME }
      }
    )

    upload_to_testflight(
      api_key: api_key,
      app_identifier: APP_IDENTIFIER,
      skip_waiting_for_build_processing: true
    )
  end

  desc "One-time: register the App ID and generate + store signing assets"
  lane :bootstrap do
    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_KEY_CONTENT"],
      is_key_content_base64: true
    )

    # Register the App ID (bundle identifier) on the Developer Portal if missing.
    # The App Store Connect API can manage identifiers (unlike the app *record*,
    # which has no API and must be created in the web UI).
    require "spaceship"
    Spaceship::ConnectAPI.token = Spaceship::ConnectAPI::Token.create(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      filepath: File.expand_path(ENV["ASC_KEY_P8"])
    )
    if Spaceship::ConnectAPI::BundleId.all.any? { |b| b.identifier == APP_IDENTIFIER }
      UI.success("Bundle ID #{APP_IDENTIFIER} already registered")
    else
      Spaceship::ConnectAPI::BundleId.create(name: "Schrift", identifier: APP_IDENTIFIER, platform: "IOS")
      UI.success("Registered bundle ID #{APP_IDENTIFIER}")
    end

    # Import into an isolated throwaway keychain so match never touches — or
    # pops a GUI password prompt on — the login keychain.
    keychain = "schrift-bootstrap.keychain"
    keychain_password = "schrift-bootstrap"
    begin
      delete_keychain(name: keychain)
    rescue StandardError
      # not present yet — fine
    end
    create_keychain(
      name: keychain,
      password: keychain_password,
      default_keychain: false,
      unlock: true,
      timeout: 3600,
      lock_when_sleeps: false
    )

    # Generate the Apple Distribution certificate + App Store provisioning
    # profile and push them (encrypted) to the match certificates repo.
    begin
      match(
        type: "appstore",
        app_identifier: APP_IDENTIFIER,
        api_key: api_key,
        readonly: false,
        keychain_name: keychain,
        keychain_password: keychain_password
      )
    ensure
      delete_keychain(name: keychain)
    end
  end
end
